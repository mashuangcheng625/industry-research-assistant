# ==================== 旧版 LLM 配置（仅保持兼容） ====================
# 新聊天链路优先使用下方 LOCAL_LLM_* / CLOUD_LLM_* 配置。
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=industry-qwen3:4b

# ==================== 模型路由 ====================
MODEL_ROUTING_MODE=local
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_MODEL=industry-qwen3:4b
AGENT_LLM_REQUEST_TIMEOUT_SECONDS=120
AGENT_LLM_MAX_RETRIES=1
AGENT_TIMEOUT_SECONDS=180
RESEARCH_RUN_LOCK_TTL_SECONDS=3600
LOCAL_LLM_MAX_OUTPUT_TOKENS=2048
LOCAL_LLM_TEMPERATURE=0
CHAT_LOG_FULL_PROMPT=false
RAG_CONTEXT_TOKEN_BUDGET=6000
# 实验性：结构化逐论断校验与二次语义裁判，默认均关闭
RAG_STRUCTURED_GROUNDING_ENABLED=false
RAG_CLAIM_MIN_LEXICAL_SUPPORT=0.12
RAG_SEMANTIC_ENTAILMENT_ENABLED=false
# local/cloud/auto；可与主生成模型分离，未设置时沿用本次生成路由
RAG_ENTAILMENT_MODEL_MODE=local
RAG_ENTAILMENT_REQUEST_TIMEOUT_SECONDS=60
RAG_ENTAILMENT_MAX_EVIDENCE_CHARS=2400
RAG_ENTAILMENT_MAX_OUTPUT_TOKENS=1024

# 云端配置可使用任意 OpenAI 兼容 API；未配置时 auto 会回退本地
CLOUD_LLM_PROVIDER=deepseek
CLOUD_LLM_API_KEY=sk-你的deepseek-api-key
CLOUD_LLM_BASE_URL=https://api.deepseek.com/v1
CLOUD_LLM_MODEL=deepseek-v4-pro
CLOUD_LLM_MAX_OUTPUT_TOKENS=4096
CLOUD_LLM_TEMPERATURE=0.2

# ==================== 本地 Embedding ====================
# Embedding 与生成模型独立；即使生成切换到云端，检索仍可保持本地。
EMBEDDING_API_KEY=ollama
EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=10
EMBEDDING_MAX_RETRIES=2
EMBEDDING_PROGRESS_EVERY_BATCHES=10

# ==================== OpenRouter API ====================
# OpenRouter API Key（可选，用于多模型支持）
# 申请地址: https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key

# ==================== 文档解析 (DocMind) ====================
# 阿里云 DocMind 文档解析服务（可选）
# 申请地址: https://help.aliyun.com/zh/ram/user-guide/create-an-accesskey-pair
DOCMIND_ACCESS_KEY_ID=your-access-key-id
DOCMIND_ACCESS_KEY_SECRET=your-access-key-secret

# ==================== 搜索 API ====================
# 博查搜索 API（必填）
# 申请地址: https://open.bochaai.com/
BOCHA_API_KEY=your-bocha-api-key

# Serper 搜索 API（可选）
SERPER_API_KEY=your-serper-api-key

# ==================== 行业资讯 API ====================
# 聚合数据 - 股票行情 API（可选）
# 申请地址: https://www.juhe.cn/docs/api/id/21
JUHE_STOCK_API_KEY=your-juhe-stock-api-key

# ==================== 招投标 API ====================
# 阿里云市场 - 招投标信息 API（可选）
# 申请地址: https://market.aliyun.com/detail/cmapi00063550
BID_APP_KEY=your-bid-app-key
BID_APP_SECRET=your-bid-app-secret
BID_APP_CODE=your-bid-app-code

# ==================== Redis ====================
# Docker 默认配置，通常无需修改
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== PostgreSQL ====================
# Docker 默认配置，与 docker-compose.yml 保持一致
# 如果使用 Docker，无需修改以下配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=industry_assistant

# ==================== Milvus ====================
# Docker 默认配置，通常无需修改
MILVUS_HOST=localhost
MILVUS_PORT=19530
# 可选：设为 /tmp/research-assistant.db 时使用 Milvus Lite，优先级高于 HOST/PORT
MILVUS_URI=
# 余弦相似度低于该值的切片不会进入模型上下文
RAG_MIN_SCORE=0.50
RAG_HYBRID_ENABLED=true
RAG_VECTOR_WEIGHT=0.75
RAG_LEXICAL_WEIGHT=0.25
RAG_MIN_LEXICAL_SCORE=0.18
RAG_LEXICAL_SCAN_LIMIT=10000
RAG_NEIGHBOR_ENABLED=true
RAG_NEIGHBOR_WINDOW=1
RAG_MAX_NEIGHBOR_CHUNKS=4
RAG_EXACT_TERM_WEIGHT=0.20
RAG_MULTI_QUERY_ENABLED=true
RAG_MULTI_QUERY_LIMIT=6
RAG_MULTI_QUERY_EXTRA_RESULTS=3
RAG_MULTI_QUERY_TOTAL_EXTRA_RESULTS=2
RAG_QUERY_FACET_LEXICAL_SCORE=0.20
RAG_QUERY_FOCUS_WEIGHT=0.55
RAG_DOCUMENT_COVERAGE_WEIGHT=0.12
RAG_MAX_CHUNKS_PER_DOCUMENT=3
RAG_CHUNK_CACHE_TTL_SECONDS=300
# 查询含 QFAB-X99 等具体型号时，至少命中其中一个才准入文档
RAG_REQUIRE_ANY_STRICT_IDENTIFIER=true

# ==================== JWT 认证 ====================
# 建议生成一个随机密钥，生产环境务必修改
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 仅隔离的本地演示可以设为 true；预发布和生产必须保持 false
ALLOW_INSECURE_DEMO_SECRET=false

# ==================== API 限流 ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_STANDARD_PER_MINUTE=60
RATE_LIMIT_RESEARCH_PER_MINUTE=10
MAX_UPLOAD_BYTES=20971520

# ==================== 其他配置 ====================
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTO_CREATE_TABLES=true
ENABLE_SCHEDULER=true
READINESS_TIMEOUT_SECONDS=3
# 完整应用部署建议开启；仅存储开发环境可保持 false
READINESS_CHECK_MODELS=false
MEM_LIMIT=8073741824
TIMEZONE=Asia/Shanghai
